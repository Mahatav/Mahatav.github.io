---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../data/portfolio.json";

const { profile, featured, experiments, research, skills } = data;
const web3formsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? "";
const orbitPositions = [
  "orbit-card--one",
  "orbit-card--two",
  "orbit-card--three",
  "orbit-card--four",
  "orbit-card--five",
];
---

<BaseLayout
  title={`${profile.name} — Developer & AI/ML Researcher`}
  description="Portfolio of Mahatav Arora: full-stack systems, expressive websites, computer vision, and applied AI research."
>
  <div class="noise" aria-hidden="true"></div>
  <div class="cursor-orb" aria-hidden="true"></div>

  <header class="site-header">
    <button class="menu-button" type="button" aria-label="Open navigation" aria-expanded="false">
      <span></span><span></span>
    </button>
    <a class="wordmark" href="#top" aria-label="Mahatav Arora, home">
      <span class="dot-grid" aria-hidden="true">M</span>
      <span>MAHATAV / ARORA</span>
    </a>
    <a class="contact-button" href="#contact-form" aria-label="Open contact form">
      <span>LET'S TALK</span>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </header>

  <nav class="menu-panel" aria-label="Primary navigation">
    <span class="menu-index">INDEX / 01—05</span>
    <a href="#work">Selected work <span>01</span></a>
    <a href="#lab">Experiments <span>02</span></a>
    <a href="#research">Research <span>03</span></a>
    <a href="#about">About <span>04</span></a>
    <a href="#contact">Contact <span>05</span></a>
  </nav>

  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-meta hero-meta--left">
        <span>BASED IN</span>
        <strong>{profile.location}</strong>
      </div>
      <div class="hero-meta hero-meta--right">
        <span>FIELD NOTES</span>
        <strong>2023—2026</strong>
      </div>

      <div class="hero-copy">
        <p class="kicker">Developer / researcher / careful tinkerer</p>
        <h1 id="hero-title">
          Building useful<br />
          <em>things with signal.</em>
        </h1>
        <p class="hero-intro">{profile.intro}</p>
      </div>

      <div class="signal-sculpture" aria-label="MA monogram sculpture">
        <div class="halo halo--outer"></div>
        <div class="halo halo--inner"></div>
        <div class="signal-disc">
          <span class="signal-disc__label">MA</span>
          <div class="scanline"></div>
        </div>
        <div class="satellite satellite--a">WEB</div>
        <div class="satellite satellite--b">AI</div>
        <div class="satellite satellite--c">DATA</div>
      </div>

      <div class="orbit-field" aria-label="Featured project shortcuts">
        {
          featured.map((project, index) => (
            <button
              class={`orbit-card ${orbitPositions[index]}`}
              type="button"
              data-project={project.id}
              style={`--accent:${project.accent}`}
              aria-label={`Open ${project.title}`}
            >
              <span class="orbit-card__visual">
                <span class="orbit-card__mark">{project.mark}</span>
                <span class="orbit-card__rings"></span>
              </span>
              <span class="orbit-card__name">{project.title}</span>
              <span class="orbit-card__type">{project.type}</span>
            </button>
          ))
        }
      </div>

      <div class="hero-console">
        <div class="console-topline">
          <span>MA.OS / PORTFOLIO</span>
          <span class="live-indicator"><i></i> ONLINE</span>
        </div>
        <div class="console-body">
          <div>
            <span class="console-label">CURRENT MODE</span>
            <strong>FULL-STACK + APPLIED AI</strong>
          </div>
          <p>{profile.availability}</p>
        </div>
        <div class="console-actions">
          <a href="#work">ENTER THE WORK <span>↓</span></a>
          <a href={`${import.meta.env.BASE_URL}Mahatav_Arora_Resume.pdf`} target="_blank">RESUME <span>↗</span></a>
        </div>
      </div>

      <span class="scroll-note">SCROLL TO EXPLORE <i></i></span>
    </section>

    <section class="section work-section" id="work">
      <div class="section-heading">
        <div>
          <span class="section-number">01 / SELECTED WORK</span>
          <h2>Client systems &<br /><em>serious experiments.</em></h2>
        </div>
        <p>Web work that earns its keep: expressive where it should be, invisible where it needs to be, and engineered for the person using it.</p>
      </div>

      <div class="filter-row" role="group" aria-label="Filter selected work">
        <button class="filter-button is-active" type="button" data-filter="all">All work</button>
        <button class="filter-button" type="button" data-filter="web">Web</button>
        <button class="filter-button" type="button" data-filter="ai">AI / ML</button>
        <button class="filter-button" type="button" data-filter="systems">Systems</button>
      </div>

      <div class="project-grid">
        {
          featured.map((project, index) => (
            <article class="project-card" data-category={project.category} style={`--accent:${project.accent}`}>
              <button type="button" data-project={project.id} aria-label={`Read about ${project.title}`}>
                <div class="project-card__topline">
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <span>{project.eyebrow}</span>
                </div>
                <div class="project-card__art" aria-hidden="true">
                  <span class="project-card__mark">{project.mark}</span>
                  <span class="art-axis art-axis--x"></span>
                  <span class="art-axis art-axis--y"></span>
                  <span class="art-dot art-dot--a"></span>
                  <span class="art-dot art-dot--b"></span>
                  <span class="art-caption">{project.type}</span>
                </div>
                <div class="project-card__copy">
                  <h3>{project.title}</h3>
                  <p>{project.summary}</p>
                  <span class="open-label">OPEN CASE NOTE <i>↗</i></span>
                </div>
              </button>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section lab-section" id="lab">
      <div class="lab-intro">
        <span class="section-number">02 / BUILD LAB</span>
        <h2>Machines that<br /><em>look back.</em></h2>
        <p>Computer-vision prototypes built to understand the full loop: sensing, deciding, and moving something in the physical world.</p>
      </div>
      <div class="experiment-list">
        {
          experiments.map((item, index) => (
            <article class="experiment-row">
              <span class="experiment-index">{String(index + 1).padStart(2, "0")}</span>
              <div class="experiment-scope" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
              <div class="experiment-copy">
                <span>{item.year} / {item.category}</span>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </div>
              <div class="tag-stack">{item.stack.map((tag) => <span>{tag}</span>)}</div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section research-section" id="research">
      <div class="section-heading section-heading--research">
        <div>
          <span class="section-number">03 / RESEARCH LOG</span>
          <h2>Questions worth<br /><em>building around.</em></h2>
        </div>
        <p>Directed studies supervised by Dr. Bowen Hui at UBC Okanagan, spanning language-model behavior, code provenance, and software process.</p>
      </div>
      <div class="research-track">
        {
          research.map((item, index) => (
            <article class="research-card">
              <div class="research-card__meta">
                <span>R-{String(index + 1).padStart(2, "0")}</span>
                <span>{item.period}</span>
              </div>
              <span class="research-code">{item.code}</span>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <div class="research-tags">{item.tags.map((tag) => <span>{tag}</span>)}</div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section about-section" id="about">
      <div class="about-statement">
        <span class="section-number">04 / OPERATING NOTES</span>
        <p>I like projects with a strange edge and a practical center—where <em>research discipline</em>, strong interaction design, and reliable infrastructure all have to get along.</p>
      </div>

      <div class="about-grid">
        <article class="education-card">
          <span class="card-label">EDUCATION</span>
          <span class="education-mark">UBC<span>O</span></span>
          <h3>B.Sc. Computer Science</h3>
          <p>Minor in Data Science<br />University of British Columbia<br />2023—2026</p>
        </article>
        <article class="skills-card">
          <span class="card-label">WORKING SET</span>
          <div class="skill-columns">
            <div><strong>LANGUAGES</strong>{skills.languages.map((skill) => <span>{skill}</span>)}</div>
            <div><strong>PLATFORMS</strong>{skills.platforms.map((skill) => <span>{skill}</span>)}</div>
            <div><strong>DATA / VISION</strong>{skills.data.map((skill) => <span>{skill}</span>)}</div>
            <div><strong>TOOLS</strong>{skills.tools.map((skill) => <span>{skill}</span>)}</div>
          </div>
        </article>
      </div>
    </section>

    <section class="contact-section" id="contact">
      <span class="contact-orbit" aria-hidden="true"></span>
      <span class="section-number">05 / CONTACT</span>
      <p>Have an unruly website, an applied AI idea, or a system that needs a clearer shape?</p>
      <a class="contact-link" href="#contact-form">Let’s make it useful.<span>↗</span></a>
      <form
        id="contact-form"
        class="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
      >
        <input type="hidden" name="access_key" value={web3formsAccessKey} />
        <input type="hidden" name="subject" value="New portfolio contact request" />
        <input type="hidden" name="from_name" value="Mahatav Portfolio" />
        <input type="checkbox" name="botcheck" class="sr-only" tabindex="-1" autocomplete="off" />

        <label>
          <span>Name</span>
          <input type="text" name="name" placeholder="Your name" required />
        </label>
        <label>
          <span>Email</span>
          <input type="email" name="email" placeholder="you@example.com" required />
        </label>
        <label class="contact-form__full">
          <span>Message</span>
          <textarea name="message" rows="5" placeholder="Tell me what you're building." required></textarea>
        </label>
        <button type="submit">Send Message <span>↗</span></button>
      </form>
      <div class="contact-footer">
        <span>{profile.name} · {profile.location}</span>
        <div>
          <a href={profile.github} target="_blank">GitHub ↗</a>
          <a href={profile.linkedin} target="_blank">LinkedIn ↗</a>
          <a href={`${import.meta.env.BASE_URL}Mahatav_Arora_Resume.pdf`} target="_blank">Resume ↗</a>
        </div>
        <span>© {new Date().getFullYear()}</span>
      </div>
    </section>
  </main>

  <dialog class="project-dialog">
    <button class="dialog-close" type="button" aria-label="Close project">CLOSE <span>×</span></button>
    <div class="dialog-content"></div>
  </dialog>

  <script is:inline id="portfolio-data" type="application/json" set:html={JSON.stringify(featured)}></script>

  <script>
    interface Project {
      id: string;
      title: string;
      eyebrow: string;
      mark: string;
      accent: string;
      summary: string;
      description: string;
      highlights: string[];
      stack: string[];
    }

    const dataNode = document.querySelector<HTMLScriptElement>("#portfolio-data");
    const projects = JSON.parse(dataNode?.textContent ?? "[]") as Project[];
    const menuButton = document.querySelector<HTMLButtonElement>(".menu-button");
    const menuPanel = document.querySelector<HTMLElement>(".menu-panel");
    const dialog = document.querySelector<HTMLDialogElement>(".project-dialog");
    const dialogContent = document.querySelector<HTMLElement>(".dialog-content");
    const closeButton = document.querySelector<HTMLButtonElement>(".dialog-close");
    const cursorOrb = document.querySelector<HTMLElement>(".cursor-orb");

    menuButton?.addEventListener("click", () => {
      const isOpen = menuPanel?.classList.toggle("is-open");
      menuButton.classList.toggle("is-open", isOpen);
      menuButton.setAttribute("aria-expanded", String(isOpen));
    });

    menuPanel?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menuPanel.classList.remove("is-open");
        menuButton?.classList.remove("is-open");
        menuButton?.setAttribute("aria-expanded", "false");
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-project]").forEach((button) => {
      button.addEventListener("click", () => {
        const project = projects.find((item) => item.id === button.dataset.project);
        if (!project || !dialog || !dialogContent) return;
        dialogContent.style.setProperty("--accent", project.accent);
        dialogContent.innerHTML = `
          <div class="dialog-visual" style="--accent:${project.accent}">
            <span class="dialog-mark">${project.mark}</span>
            <i></i><i></i><i></i>
          </div>
          <div class="dialog-copy">
            <span class="dialog-eyebrow">${project.eyebrow}</span>
            <h2>${project.title}</h2>
            <p class="dialog-summary">${project.summary}</p>
            <p class="dialog-description">${project.description}</p>
            <div class="dialog-highlights">
              ${project.highlights.map((item, index) => `<span><i>0${index + 1}</i>${item}</span>`).join("")}
            </div>
            <div class="dialog-stack">${project.stack.map((item) => `<span>${item}</span>`).join("")}</div>
          </div>
        `;
        dialog.showModal();
        document.body.classList.add("dialog-open");
      });
    });

    const unlockPageScroll = () => {
      document.body.classList.remove("dialog-open");
    };

    const closeDialog = () => {
      if (dialog?.open) dialog.close();
      unlockPageScroll();
    };

    closeButton?.addEventListener("click", closeDialog);
    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) closeDialog();
    });
    dialog?.addEventListener("cancel", unlockPageScroll);
    dialog?.addEventListener("close", unlockPageScroll);

    document.querySelectorAll<HTMLButtonElement>(".filter-button").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".filter-button").forEach((item) => item.classList.remove("is-active"));
        button.classList.add("is-active");
        const filter = button.dataset.filter;
        document.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
          card.classList.toggle("is-hidden", filter !== "all" && card.dataset.category !== filter);
        });
      });
    });

    if (window.matchMedia("(pointer: fine)").matches) {
      window.addEventListener("pointermove", (event) => {
        cursorOrb?.style.setProperty("--x", `${event.clientX}px`);
        cursorOrb?.style.setProperty("--y", `${event.clientY}px`);
      });
    }

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".project-card, .experiment-row, .research-card, .about-grid").forEach((element) => {
      revealObserver.observe(element);
    });
  </script>
</BaseLayout>
