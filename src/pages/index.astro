---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../data/portfolio.json";
import SiteHeader from "../components/SiteHeader.astro";
import Hero from "../components/Hero.astro";
import SelectedWork from "../components/SelectedWork.astro";
import BuildLab from "../components/BuildLab.astro";
import ResearchLog from "../components/ResearchLog.astro";
import Packages from "../components/Packages.astro";
import OperatingNotes from "../components/OperatingNotes.astro";
import Faq from "../components/Faq.astro";
import Contact from "../components/Contact.astro";
import ProjectDialog from "../components/ProjectDialog.astro";

const { profile, featured } = data;
---

<BaseLayout
  title={`${profile.name} · Custom Websites for Businesses`}
  description="Mahatav Arora builds custom websites and online tools that help businesses look professional, get found on Google, and win more customers. Available for new projects."
>
  <div class="noise" aria-hidden="true"></div>
  <div class="cursor-orb" aria-hidden="true"></div>

  <SiteHeader />

  <main id="top">
    <Hero />
    <SelectedWork />
    <Packages />
    <BuildLab />
    <ResearchLog />
    <OperatingNotes />
    <Faq />
    <Contact />
  </main>

  <ProjectDialog />

  <script is:inline id="portfolio-data" type="application/json" set:html={JSON.stringify(featured)}></script>

  <script>
    interface Project {
      id: string;
      title: string;
      eyebrow: string;
      mark: string;
      accent: string;
      summary: string;
      description: string;
      highlights: string[];
      stack: string[];
      services?: string[];
      proof?: string[];
      showcaseVideo?: string;
      showcasePoster?: string;
      reelLabel?: string;
      image?: string;
      imageCaption?: string;
      websiteUrl?: string;
      githubUrl?: string;
    }

    const dataNode = document.querySelector<HTMLScriptElement>("#portfolio-data");
    const projects = JSON.parse(dataNode?.textContent ?? "[]") as Project[];
    const menuButton = document.querySelector<HTMLButtonElement>(".menu-button");
    const menuPanel = document.querySelector<HTMLElement>(".menu-panel");
    const dialog = document.querySelector<HTMLDialogElement>(".project-dialog");
    const dialogContent = document.querySelector<HTMLElement>(".dialog-content");
    const closeButton = document.querySelector<HTMLButtonElement>(".dialog-close");
    const cursorOrb = document.querySelector<HTMLElement>(".cursor-orb");

    menuButton?.addEventListener("click", () => {
      const isOpen = menuPanel?.classList.toggle("is-open");
      menuButton.classList.toggle("is-open", isOpen);
      menuButton.setAttribute("aria-expanded", String(isOpen));
    });

    menuPanel?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menuPanel.classList.remove("is-open");
        menuButton?.classList.remove("is-open");
        menuButton?.setAttribute("aria-expanded", "false");
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-project]").forEach((button) => {
      button.addEventListener("click", () => {
        const project = projects.find((item) => item.id === button.dataset.project);
        if (!project || !dialog || !dialogContent) return;
        dialogContent.style.setProperty("--accent", project.accent);
        dialogContent.innerHTML = `
          <div class="dialog-visual ${project.showcaseVideo || project.image ? "dialog-visual--showcase" : ""}" style="--accent:${project.accent}">
            ${project.showcaseVideo ? `
              <img
                class="dialog-showcase-backdrop"
                src="${project.showcasePoster ?? ""}"
                alt=""
                aria-hidden="true"
              />
              <video
                class="dialog-showcase-video"
                src="${project.showcaseVideo}"
                poster="${project.showcasePoster ?? ""}"
                muted
                autoplay
                loop
                playsinline
                preload="auto"
              ></video>
              <span class="dialog-reel-kicker">${project.reelLabel ?? "LIVE BUILD / MAIN SITE → ARCHIVE"}</span>
            ` : project.image ? `
              <img class="dialog-image" src="${project.image}" alt="${project.title} · ${project.imageCaption ?? "screenshot"}" />
              ${project.imageCaption ? `<span class="dialog-reel-kicker">${project.imageCaption}</span>` : ""}
            ` : `
              <span class="dialog-mark">${project.mark}</span>
              <i></i><i></i><i></i>
            `}
          </div>
          <div class="dialog-copy">
            <span class="dialog-eyebrow">${project.eyebrow}</span>
            <h2>${project.title}</h2>
            <p class="dialog-summary">${project.summary}</p>
            <p class="dialog-description">${project.description}</p>
            ${project.proof ? `
              <div class="dialog-proof">
                ${project.proof.map((item) => `<span>${item}</span>`).join("")}
              </div>
            ` : ""}
            <div class="dialog-highlights">
              ${project.highlights.map((item, index) => `<span><i>0${index + 1}</i>${item}</span>`).join("")}
            </div>
            ${project.services ? `
              <div class="dialog-services">
                <small>WHAT I DELIVERED</small>
                <div>${project.services.map((item) => `<span>${item}</span>`).join("")}</div>
              </div>
            ` : ""}
            ${project.websiteUrl || project.githubUrl ? `
              <div class="dialog-actions">
                ${project.websiteUrl ? `
                  <a class="dialog-action--primary" href="${project.websiteUrl}" target="_blank" rel="noreferrer">
                    <span>EXPLORE THE LIVE BUILD</span>
                    <i>VISIT SITE ↗</i>
                  </a>
                ` : ""}
                ${project.githubUrl ? `
                  <a href="${project.githubUrl}" target="_blank" rel="noreferrer">
                    <span>INSPECT THE SOURCE</span>
                    <i>GITHUB ↗</i>
                  </a>
                ` : ""}
                <a href="#contact-form" data-book-project>
                  <span>HAVE A PROJECT IN MIND?</span>
                  <i>BOOK MAHATAV ↗</i>
                </a>
              </div>
            ` : ""}
            <div class="dialog-stack">${project.stack.map((item) => `<span>${item}</span>`).join("")}</div>
          </div>
        `;
        dialogContent.querySelector("[data-book-project]")?.addEventListener("click", (event) => {
          event.preventDefault();
          dialog.close();
          document.body.classList.remove("dialog-open");
          document.querySelector("#contact-form")?.scrollIntoView({ behavior: "smooth", block: "center" });
        });
        dialog.showModal();
        dialog.scrollTop = 0;
        document.body.classList.add("dialog-open");
      });
    });

    const unlockPageScroll = () => {
      document.body.classList.remove("dialog-open");
    };

    const closeDialog = () => {
      if (dialog?.open) dialog.close();
      unlockPageScroll();
    };

    closeButton?.addEventListener("click", closeDialog);
    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) closeDialog();
    });
    dialog?.addEventListener("cancel", unlockPageScroll);
    dialog?.addEventListener("close", unlockPageScroll);

    document.querySelectorAll<HTMLButtonElement>(".filter-button").forEach((button) => {
      button.addEventListener("click", () => {
        document.querySelectorAll(".filter-button").forEach((item) => item.classList.remove("is-active"));
        button.classList.add("is-active");
        const filter = button.dataset.filter;
        document.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
          card.classList.toggle("is-hidden", filter !== "all" && card.dataset.category !== filter);
        });
      });
    });

    if (window.matchMedia("(pointer: fine)").matches) {
      window.addEventListener("pointermove", (event) => {
        cursorOrb?.style.setProperty("--x", `${event.clientX}px`);
        cursorOrb?.style.setProperty("--y", `${event.clientY}px`);
      });
    }

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".project-card, .experiment-row, .research-card, .package-card, .about-grid, .faq-list").forEach((element) => {
      revealObserver.observe(element);
    });
  </script>
</BaseLayout>
