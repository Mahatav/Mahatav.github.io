---
import "../styles/global.css";
import data from "../data/portfolio.json";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL("og-image.png", Astro.site);

const { profile, skills, packages, faq } = data;
const siteUrl = Astro.site?.toString() ?? "";
const personId = `${siteUrl}#person`;
const businessId = `${siteUrl}#business`;
const buildDate = new Date().toLocaleDateString("en-CA", {
  timeZone: "America/Vancouver",
});

const address = {
  "@type": "PostalAddress",
  addressLocality: "Kelowna",
  addressRegion: "BC",
  addressCountry: "CA",
};

// Build machine-readable Offers from the visible pricing tiers, parsing the
// dollar figures out of each tier's price label (e.g. "$6,000 – $15,000 CAD").
const offers = packages.tiers.map((tier) => {
  const amounts = (tier.price.match(/[\d,]+/g) ?? []).map((n) =>
    Number(n.replace(/,/g, "")),
  );
  const priceSpecification = amounts.length
    ? {
        "@type": "PriceSpecification",
        priceCurrency: "CAD",
        minPrice: amounts[0],
        ...(amounts.length > 1 ? { maxPrice: amounts[1] } : {}),
      }
    : undefined;
  return {
    "@type": "Offer",
    name: tier.name,
    category: tier.scope,
    description: tier.blurb,
    ...(priceSpecification ? { priceSpecification } : {}),
  };
});

const personSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": `${siteUrl}#profilepage`,
      url: siteUrl,
      name: `${profile.name} · Portfolio`,
      datePublished: "2026-06-18",
      dateModified: buildDate,
      mainEntity: { "@id": personId },
      about: { "@id": personId },
    },
    {
      "@type": "Person",
      "@id": personId,
      name: profile.name,
      jobTitle: profile.role,
      description: profile.intro,
      url: siteUrl,
      email: `mailto:${profile.email}`,
      telephone: profile.phone,
      address,
      knowsAbout: [
        ...skills.languages,
        ...skills.platforms,
        ...skills.data,
      ],
      sameAs: [profile.github, profile.linkedin, profile.instagram],
    },
    {
      "@type": "ProfessionalService",
      "@id": businessId,
      name: `${profile.name} — Software, AI & Web Development`,
      description: profile.intro,
      url: siteUrl,
      email: `mailto:${profile.email}`,
      telephone: profile.phone,
      image: ogImageUrl.href,
      priceRange: "$$$",
      address,
      geo: {
        "@type": "GeoCoordinates",
        latitude: 49.888,
        longitude: -119.496,
      },
      hasMap: "https://www.google.com/maps/place/Kelowna,+BC",
      founder: { "@id": personId },
      provider: { "@id": personId },
      areaServed: [
        { "@type": "City", name: "Kelowna" },
        { "@type": "AdministrativeArea", name: "British Columbia" },
        "Worldwide (remote)",
      ],
      serviceType: [
        "Software development",
        "AI development",
        "Web application development",
        "Web design",
        "Workflow automation",
        "Search engine optimization",
      ],
      sameAs: [profile.github, profile.linkedin, profile.instagram],
      makesOffer: offers,
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}#faq`,
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self'; font-src 'self'; connect-src 'self' https://api.web3forms.com; form-action https://api.web3forms.com; frame-src https://maps.google.com https://www.google.com; base-uri 'self'; object-src 'none'"
    />
    <script is:inline>
      // Clickjacking mitigation: break out if framed by another site.
      // GitHub Pages can't send X-Frame-Options, so this runs client-side.
      try {
        if (window.top && window.top !== window.self) {
          window.top.location = window.self.location.href;
        }
      } catch (e) {
        // Cross-origin parent blocks access · that itself signals framing.
        document.documentElement.style.display = "none";
      }
    </script>
    <meta name="description" content={description} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="author" content={profile.name} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="theme-color" content="#9cafaa" />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name} · ${profile.role}`} />
    <meta name="geo.region" content="CA-BC" />
    <meta name="geo.placename" content="Kelowna" />
    <meta name="geo.position" content="49.8880;-119.4960" />
    <meta name="ICBM" content="49.8880, -119.4960" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
