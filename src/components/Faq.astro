---
// Section 06 — common questions. Visible copy only; the matching FAQPage
// structured data lives in the shared graph in BaseLayout (kept in one place
// to avoid duplicate schema).
import data from "../data/portfolio.json";

const { faq } = data;
---

<section class="section faq-section" id="faq">
  <div class="faq-statement">
    <span class="section-number">06 / COMMON QUESTIONS</span>
    <p>The things people usually <em>ask first.</em></p>
  </div>
  <dl class="faq-list">
    {faq.map((item) => (
      <div class="faq-item">
        <dt>{item.question}</dt>
        <dd>{item.answer}</dd>
      </div>
    ))}
  </dl>
</section>
