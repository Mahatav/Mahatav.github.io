---
// Section 07 — contact form (Web3Forms) plus the Kelowna map and footer.
// The access key comes from an env var so it isn't hard-coded in source.
import data from "../data/portfolio.json";

const { profile } = data;
const web3formsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? "";

// "Updated <date>" line in the footer, rendered in Pacific time at build.
const lastUpdated = new Date();
const buildTimeZone = "America/Vancouver";
const lastUpdatedISO = lastUpdated.toLocaleDateString("en-CA", {
  timeZone: buildTimeZone,
});
const lastUpdatedLabel = lastUpdated.toLocaleDateString("en-US", {
  timeZone: buildTimeZone,
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<section class="contact-section" id="contact">
  <span class="contact-orbit" aria-hidden="true"></span>
  <div class="contact-body">
    <div class="contact-lead">
      <span class="section-number">07 / CONTACT</span>
      <p>Ready to build something that helps your business grow?</p>
      <a class="contact-link" href="#contact-form">Let’s build it.<span>↗</span></a>
      <form
        id="contact-form"
        class="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
      >
        <input type="hidden" name="access_key" value={web3formsAccessKey} />
        <input type="hidden" name="subject" value="New portfolio contact request" />
        <input type="hidden" name="from_name" value="Mahatav Portfolio" />
        {/* Honeypot: hidden from users, but bots tend to tick it — Web3Forms
            silently drops any submission where it's checked. */}
        <input type="checkbox" name="botcheck" class="sr-only" tabindex="-1" autocomplete="off" aria-hidden="true" aria-label="Leave this field empty" />

        <label for="contact-name">
          <span>Name</span>
          <input id="contact-name" type="text" name="name" placeholder="Your name" required />
        </label>
        <label for="contact-email">
          <span>Email</span>
          <input id="contact-email" type="email" name="email" placeholder="you@example.com" required />
        </label>
        <label class="contact-form__full" for="contact-message">
          <span>Message</span>
          <textarea id="contact-message" name="message" rows="5" placeholder="Tell me what you're building." required></textarea>
        </label>
        <button type="submit">Send Message <span>↗</span></button>
      </form>
    </div>
    <div class="contact-map">
      <iframe
        title="Map of Kelowna, BC"
        src="https://maps.google.com/maps?q=Kelowna%2C%20BC&z=11&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        aria-label="Map showing Kelowna, British Columbia, where Mahatav Arora is based"
      ></iframe>
      <a class="contact-map__tag" href="https://www.google.com/maps/place/Kelowna,+BC" target="_blank" rel="noopener noreferrer"><i></i>BASED IN KELOWNA, BC <b>↗</b></a>
    </div>
  </div>
  <div class="contact-footer">
    <span>{profile.name} · {profile.location} · <a class="contact-phone" href={profile.phoneHref}>{profile.phone}</a></span>
    <div>
      <a href={profile.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      <a href={profile.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
      <a href={profile.instagram} target="_blank" rel="noopener noreferrer">Instagram ↗</a>
      <a href={`${import.meta.env.BASE_URL}Mahatav_Arora_Resume.pdf`} target="_blank" rel="noopener">Resume ↗</a>
    </div>
    <span>Updated <time datetime={lastUpdatedISO}>{lastUpdatedLabel}</time> · © {new Date().getFullYear()}</span>
  </div>
</section>
