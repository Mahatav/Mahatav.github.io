---
// Site chrome: top header bar + slide-out navigation menu.
import data from "../data/portfolio.json";

const { profile } = data;
---

<header class="site-header">
  <button class="menu-button" type="button" aria-label="Open navigation" aria-expanded="false">
    <span></span><span></span>
  </button>
  <a class="wordmark" href="#top" aria-label="Mahatav Arora, home">
    <span>MAHATAV / ARORA</span>
  </a>
  <div class="header-actions">
    <a class="header-call" href={profile.phoneHref} aria-label={`Call ${profile.name} at ${profile.phone}`}>
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    </a>
    <a class="contact-button" href="#contact-form" aria-label="Open contact form">
      <span>LET'S TALK</span>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</header>

<nav class="menu-panel" aria-label="Primary navigation">
  <span class="menu-index">INDEX / 01–07</span>
  <a href="#work">Selected work <span>01</span></a>
  <a href="#packages">Pricing <span>02</span></a>
  <a href="#lab">Experiments <span>03</span></a>
  <a href="#research">Research <span>04</span></a>
  <a href="#about">About <span>05</span></a>
  <a href="#contact">Contact <span>07</span></a>
</nav>
