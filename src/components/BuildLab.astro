---
// Section 03 — personal R&D experiments (computer vision, robotics), listed as
// a numbered log to signal hands-on range beyond the client work.
import data from "../data/portfolio.json";

const { experiments } = data;
---

<section class="section lab-section" id="lab">
  <div class="lab-intro">
    <span class="section-number">03 / BUILD LAB</span>
    <h2>Exploring what's<br /><em>possible.</em></h2>
    <p>Personal projects in computer vision and robotics, where I experiment with new tools so the work I bring to clients stays current and capable.</p>
  </div>
  <div class="experiment-list">
    {
      experiments.map((item, index) => (
        <article class="experiment-row">
          <span class="experiment-index">{String(index + 1).padStart(2, "0")}</span>
          <div class="experiment-scope" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
          <div class="experiment-copy">
            <span>{item.year} / {item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </div>
          <div class="tag-stack">{item.stack.map((tag) => <span>{tag}</span>)}</div>
        </article>
      ))
    }
  </div>
</section>
