---
import data from "../data/portfolio.json";

const { profile, featured } = data;
const orbitPositions = [
  "orbit-card--one",
  "orbit-card--two",
  "orbit-card--three",
  "orbit-card--four",
  "orbit-card--five",
];
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-meta hero-meta--left">
    <span>BASED IN</span>
    <strong>{profile.location}</strong>
  </div>
  <div class="hero-meta hero-meta--right">
    <span>AVAILABILITY</span>
    <strong>OPEN FOR PROJECTS</strong>
  </div>

  <div class="hero-copy">
    <h1 id="hero-title">
      Tech that works<br />
      <em>for your business.</em>
    </h1>
  </div>

  <div class="signal-sculpture" aria-label="MA monogram sculpture">
    <div class="halo halo--outer"></div>
    <div class="halo halo--inner"></div>
    <div class="signal-disc">
      <span class="signal-disc__label">MA</span>
      <div class="scanline"></div>
    </div>
    <div class="electron-field" aria-hidden="true">
      <div class="orbit orbit--outer" style="--d:0s"><span class="satellite"><b>WEB</b></span></div>
      <div class="orbit orbit--outer" style="--d:-8.67s"><span class="satellite satellite--acid"><b>AI</b></span></div>
      <div class="orbit orbit--outer" style="--d:-17.33s"><span class="satellite satellite--orange"><b>DATA</b></span></div>
      <div class="orbit orbit--inner" style="--d:0s"><span class="satellite satellite--mint satellite--area"><b>SYSTEMS</b></span></div>
      <div class="orbit orbit--inner" style="--d:-6.33s"><span class="satellite satellite--lilac satellite--area"><b>APPLICATIONS</b></span></div>
      <div class="orbit orbit--inner" style="--d:-12.67s"><span class="satellite satellite--peach satellite--area"><b>RESEARCH</b></span></div>
    </div>
  </div>

  <div class="orbit-field" aria-label="Featured project shortcuts">
    {
      featured.map((project, index) => (
        <button
          class={`orbit-card ${orbitPositions[index]}`}
          type="button"
          data-project={project.id}
          style={`--accent:${project.accent}`}
          aria-label={`Open ${project.title}`}
        >
          <span class="orbit-card__visual">
            {project.showcaseVideo ? (
              <video
                class="orbit-card__video"
                src={project.showcaseVideo}
                poster={project.showcasePoster}
                muted
                autoplay
                loop
                playsinline
                preload="metadata"
                aria-hidden="true"
              ></video>
            ) : (
              <span class="orbit-card__mark">{project.mark}</span>
            )}
            <span class="orbit-card__rings"></span>
          </span>
          <span class="orbit-card__name">{project.title}</span>
          <span class="orbit-card__type">{project.type}</span>
        </button>
      ))
    }
  </div>

  <div class="hero-console">
    <div class="console-topline">
      <span>MA.OS / PORTFOLIO</span>
      <span class="live-indicator"><i></i> ONLINE</span>
    </div>
    <div class="console-body">
      <div>
        <span class="console-label">STATUS</span>
        <strong>TAKING ON NEW WORK</strong>
      </div>
      <p>{profile.availability}</p>
    </div>
    <div class="console-actions">
      <a href="#contact-form">START A PROJECT <span>↗</span></a>
      <a href="#packages">SEE HOW WE'D WORK <span>↓</span></a>
    </div>
  </div>

  <span class="scroll-note">SCROLL TO EXPLORE <i></i></span>
</section>
